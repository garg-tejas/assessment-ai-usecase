# --- LLM provider keys ---
# Set the key for whichever provider(s) you use.

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Z.ai (https://api.z.ai)
ZAI_API_KEY=

# Custom provider - only needed if you pick "Custom" in the sidebar
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- Embeddings ---
# Gemini API key for gemini-embedding-001 (RAG). Usually the same as GEMINI_API_KEY.
EMBEDDING_API_KEY=

# --- Web search ---
# Exa API key for live neural web search (https://exa.ai)
EXA_API_KEY=
